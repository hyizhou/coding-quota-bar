{
  "appId": "com.codingquotabar.app",
  "productName": "Coding Quota Bar",
  "copyright": "Copyright © 2026 coding-quota-bar-team",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "version": "0.1.0"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Coding Quota Bar",
    "perMachine": false
  },
  "portable": {
    "artifactName": "${productName}-${version}-portable.${ext}"
  }
}
